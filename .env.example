# =====================================================
# FlowAI Voice Agent — Umgebungsvariablen
# Kopiere diese Datei nach .env.local und fülle die Werte aus
# =====================================================

# ----- PFLICHT: VAPI (Voice Platform) -----
# Account erstellen: https://vapi.ai
# Public Key: Dashboard → Account → API Keys → Public Key
NEXT_PUBLIC_VAPI_PUBLIC_KEY=vapi_public_xxxxxx

# Optional: Vorkonfigurierter Assistent-ID aus VAPI Dashboard
# Wenn leer → Agent wird inline konfiguriert (kein VAPI-Dashboard nötig)
NEXT_PUBLIC_VAPI_ASSISTANT_ID=

# Optional aber empfohlen: Webhook-Absicherung für /api/vapi/webhook
# Akzeptiert x-vapi-secret / x-webhook-secret oder Bearer-Token mit diesem Wert.
VAPI_WEBHOOK_SECRET=

# ----- OPTIONAL: Anthropic (Emotion + Gesprächs-Summary) -----
# Ohne Key wird ein lokaler Fallback für Summaries verwendet, Emotionsanalyse bleibt neutral.
ANTHROPIC_API_KEY=sk-ant-...

# ----- OPTIONAL: Cal.com (Terminbuchung) -----
# Account erstellen: https://cal.com
# API Key: Settings → Developer → API Keys
CALCOM_API_KEY=cal_live_xxxxxx
# Event Type ID: Aus der Event-URL
CALCOM_EVENT_TYPE_ID=123456
